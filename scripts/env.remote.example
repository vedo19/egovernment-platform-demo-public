# Remote DB development environment example
# Copy to .env.remote in project root and fill in values.

JWT_SECRET_KEY=replace_with_same_jwt_key_used_by_all_services
ADMIN_EMAIL=admin@government.gov
ADMIN_PASSWORD=replace_with_admin_password
ADMIN_FULLNAME=System Administrator

# Auth database
# For local `make dev-remote-db`, this must be the public/external Render Postgres hostname.
# Internal `dpg-...` hostnames only work inside Render's private network.
AuthDb__Host=your-auth-db-host
AuthDb__Port=5432
AuthDb__Database=your-auth-db-name
AuthDb__Username=your-auth-db-user
AuthDb__Password=your-auth-db-password
AuthDb__SslMode=Require

# Citizen database
CitizenDb__Host=your-citizen-db-host
CitizenDb__Port=5432
CitizenDb__Database=your-citizen-db-name
CitizenDb__Username=your-citizen-db-user
CitizenDb__Password=your-citizen-db-password
CitizenDb__SslMode=Require

# Service Request database
RequestDb__Host=your-request-db-host
RequestDb__Port=5432
RequestDb__Database=your-request-db-name
RequestDb__Username=your-request-db-user
RequestDb__Password=your-request-db-password
RequestDb__SslMode=Require

# Document database
DocumentDb__Host=your-document-db-host
DocumentDb__Port=5432
DocumentDb__Database=your-document-db-name
DocumentDb__Username=your-document-db-user
DocumentDb__Password=your-document-db-password
DocumentDb__SslMode=Require

# Gateway + CORS (local dev)
AuthService__Url=http://auth_service:8080
CitizenService__Url=http://citizen_service:8080
ServiceRequestService__Url=http://service_request_service:8080
DocumentService__Url=http://document_service:8080
Cors__AllowedOrigins__0=http://localhost:3000
Cors__AllowedOrigins__1=http://localhost:5173
